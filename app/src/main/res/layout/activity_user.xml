<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E3735"
    android:id="@+id/main"
    tools:context=".UserActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Tombol Home & Pengaturan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:padding="10dp">

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_pengaturan"
                    android:contentDescription="Pengaturan"
                    android:layout_marginEnd="10dp"/>

                <ImageButton
                    android:id="@+id/btnHome"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_home"
                    android:contentDescription="Home"/>
            </LinearLayout>

            <!-- CardView untuk Profil User -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                android:padding="20dp"
                android:background="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <!-- Foto Profil dengan Menu -->
                    <ImageButton
                        android:id="@+id/imgProfile"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/ic_userdefault"
                        android:scaleType="centerCrop"
                        android:background="@drawable/circle_border"
                        android:contentDescription="Foto Profil"
                        android:layout_marginBottom="10dp"/>

                    <!-- Informasi User -->
                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Profil"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:textColor="#000000"
                        android:gravity="center"
                        android:layout_marginBottom="10dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@android:color/darker_gray"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Username : xra"
                        android:textSize="14sp"
                        android:textColor="#000000"
                        android:padding="5dp"
                        android:textStyle="bold"
                        android:fontFamily="serif"/>

                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Email         : 12350123200@students.uin-suska.ac.id"
                        android:textSize="14sp"
                        android:textColor="#000000"
                        android:padding="5dp"
                        android:textStyle="bold"
                        android:fontFamily="serif"/>

                    <TextView
                        android:id="@+id/tvNIM"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NIM           : 12350123200"
                        android:textSize="14sp"
                        android:textColor="#000000"
                        android:padding="5dp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:layout_marginBottom="5dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Logout Button -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="12dp"
                android:backgroundTint="@color/white"
                android:textColor="@color/black"
                android:layout_marginTop="10dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
