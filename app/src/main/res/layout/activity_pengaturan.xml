<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ic_3"
    tools:context=".Pengaturan">

    <!-- Navbar di kanan atas -->
    <include
        android:id="@+id/include_navbar"
        layout="@layout/navbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="45dp"
        android:layout_marginEnd="25dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/menuPanel"
        android:layout_width="210dp"
        android:layout_height="453dp"
        android:background="@drawable/edit_text3"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.912"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.252">

        <!-- Scrollable Card Menu -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="80sp"
            android:fontFamily="serif"
            android:gravity="center"

            android:text="SETTING"
            android:textColor="@android:color/black"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="left"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/bsuara"
                android:layout_width="131dp"
                android:layout_height="30dp"
                android:layout_marginBottom="10dp"
                app:srcCompat="@drawable/ic_suara" />

            <ImageView
                android:id="@+id/bbahasa"
                android:layout_width="138dp"
                android:layout_height="35dp"
                android:layout_marginBottom="10dp"
                app:srcCompat="@drawable/ic_bahasa" />

            <ImageView
                android:id="@+id/bbantuan"
                android:layout_width="143dp"
                android:layout_height="28dp"
                android:layout_marginBottom="10dp"
                app:srcCompat="@drawable/ic_bantuan" />

            <ImageView
                android:id="@+id/btema"
                android:layout_width="191dp"
                android:layout_height="75dp"
                android:layout_marginLeft="4dp"
                android:layout_marginBottom="10dp"
                app:srcCompat="@drawable/ic_tema" />

            <ImageView
                android:id="@+id/baboutMe"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_marginLeft="145dp"
                android:layout_marginTop="55dp"
                app:srcCompat="@drawable/ic_aboutme" />

        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>